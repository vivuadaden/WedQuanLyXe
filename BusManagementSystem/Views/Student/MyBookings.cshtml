@model IEnumerable<BusManagementSystem.Models.Booking>

@{
    ViewData["Title"] = "Chuyến đi của tôi";
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="fw-bold">
                <i class="bi bi-ticket-perforated me-2"></i>Chuyến đi của tôi
            </h2>
            <p class="text-muted">Quản lý các chuyến đi bạn đã đặt</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Index" class="btn btn-primary">
                <i class="bi bi-search me-2"></i>Tìm chuyến mới
            </a>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Statistics -->
    <div class="row g-3 mb-4">
        @{
            var activeBookings = Model.Count(b => b.Status == "Đã đặt" &&
            (b.Trip.Status == "Đã xác nhận" || b.Trip.Status == "Đang đi"));
            var completedBookings = Model.Count(b => b.Trip.Status == "Hoàn thành");
            var cancelledBookings = Model.Count(b => b.Status == "Đã hủy" || b.Trip.Status == "Hủy");
        }

        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 rounded-3 p-3 me-3">
                        <i class="bi bi-ticket text-primary fs-3"></i>
                    </div>
                    <div>
                        <h4 class="mb-0 fw-bold">@activeBookings</h4>
                        <small class="text-muted">Đang hoạt động</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 rounded-3 p-3 me-3">
                        <i class="bi bi-check-circle text-success fs-3"></i>
                    </div>
                    <div>
                        <h4 class="mb-0 fw-bold">@completedBookings</h4>
                        <small class="text-muted">Hoàn thành</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-secondary bg-opacity-10 rounded-3 p-3 me-3">
                        <i class="bi bi-x-circle text-secondary fs-3"></i>
                    </div>
                    <div>
                        <h4 class="mb-0 fw-bold">@cancelledBookings</h4>
                        <small class="text-muted">Đã hủy</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Tabs -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <ul class="nav nav-pills" id="bookingFilter">
                <li class="nav-item">
                    <a class="nav-link active" href="#" data-filter="all">
                        <i class="bi bi-grid me-2"></i>Tất cả
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#" data-filter="active">
                        <i class="bi bi-arrow-repeat me-2"></i>Đang hoạt động
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#" data-filter="completed">
                        <i class="bi bi-check-circle me-2"></i>Hoàn thành
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#" data-filter="cancelled">
                        <i class="bi bi-x-circle me-2"></i>Đã hủy
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <!-- Bookings List -->
    @if (Model.Any())
    {
        <div class="row g-4" id="bookingsList">
            @foreach (var booking in Model)
            {
                var trip = booking.Trip;
                var isActive = booking.Status == "Đã đặt" && (trip.Status == "Đã xác nhận" || trip.Status == "Đang đi");
                var isCompleted = trip.Status == "Hoàn thành";
                var isCancelled = booking.Status == "Đã hủy" || trip.Status == "Hủy";

                var filterClass = isActive ? "active" : isCompleted ? "completed" : "cancelled";

                <div class="col-lg-6 booking-item" data-filter="@filterClass">
                    <div class="card border-0 shadow-sm h-100">
                        <!-- Card Header -->
                        <div class="card-header bg-white border-bottom py-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1 fw-bold">
                                        <i class="bi bi-bus-front text-primary me-2"></i>
                                        @trip.Bus?.BusNumber - @trip.Bus?.LicensePlate
                                    </h6>
                                    <small class="text-muted">
                                        <i class="bi bi-calendar3 me-1"></i>
                                        Đặt lúc: @booking.BookingTime.ToString("dd/MM/yyyy HH:mm")
                                    </small>
                                </div>
                                <div class="text-end">
                                    @if (isActive)
                                    {
                                        <span class="badge bg-success mb-1">
                                            <i class="bi bi-check-circle me-1"></i>Đang hoạt động
                                        </span>
                                    }
                                    else if (isCompleted)
                                    {
                                        <span class="badge bg-info mb-1">
                                            <i class="bi bi-check-square me-1"></i>Hoàn thành
                                        </span>
                                    }
                                    else if (isCancelled)
                                    {
                                        <span class="badge bg-secondary mb-1">
                                            <i class="bi bi-x-circle me-1"></i>Đã hủy
                                        </span>
                                    }
                                    <br>
                                    @if (trip.Status == "Đang đi")
                                    {
                                        <span class="badge bg-primary">
                                            <i class="bi bi-arrow-repeat me-1"></i>Đang đi
                                        </span>
                                    }
                                    else if (trip.Status == "Đã xác nhận")
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-clock me-1"></i>Sắp khởi hành
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Card Body -->
                        <div class="card-body">
                            <!-- Route -->
                            <div class="row mb-3">
                                <div class="col-5">
                                    <div class="text-center p-2 bg-light rounded">
                                        <i class="bi bi-geo-alt text-primary"></i>
                                        <div class="fw-bold mt-1">@trip.FromCampus?.CampusName</div>
                                        <small class="text-muted">Điểm đi</small>
                                    </div>
                                </div>
                                <div class="col-2 d-flex align-items-center justify-content-center">
                                    <i class="bi bi-arrow-right text-muted fs-4"></i>
                                </div>
                                <div class="col-5">
                                    <div class="text-center p-2 bg-light rounded">
                                        <i class="bi bi-geo-alt-fill text-success"></i>
                                        <div class="fw-bold mt-1">@trip.ToCampus?.CampusName</div>
                                        <small class="text-muted">Điểm đến</small>
                                    </div>
                                </div>
                            </div>

                            <!-- Trip Details -->
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <small class="text-muted d-block">
                                        <i class="bi bi-calendar3 me-1"></i>Ngày đi
                                    </small>
                                    <strong>@trip.DepartureTime.ToString("dd/MM/yyyy")</strong>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted d-block">
                                        <i class="bi bi-clock me-1"></i>Giờ khởi hành
                                    </small>
                                    <strong>@trip.DepartureTime.ToString("HH:mm")</strong>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted d-block">
                                        <i class="bi bi-person me-1"></i>Tài xế
                                    </small>
                                    <strong>@trip.Driver?.FullName</strong>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted d-block">
                                        <i class="bi bi-telephone me-1"></i>Liên hệ
                                    </small>
                                    <strong>@trip.Driver?.PhoneNumber</strong>
                                </div>
                            </div>

                            @if (isActive && trip.Status == "Đang đi")
                            {
                                <div class="alert alert-info mb-3">
                                    <i class="bi bi-info-circle me-2"></i>
                                    <strong>Chuyến đi đang di chuyển</strong>
                                    <div class="progress mt-2" style="height: 6px;">
                                        <div class="progress-bar progress-bar-striped progress-bar-animated"
                                             style="width: 60%"></div>
                                    </div>
                                </div>
                            }
                            else if (isActive && trip.Status == "Đã xác nhận")
                            {
                                var timeUntilDeparture = trip.DepartureTime - DateTime.Now;
                                var hoursLeft = (int)timeUntilDeparture.TotalHours;

                                if (hoursLeft <= 24 && hoursLeft >= 0)
                                {
                                    <div class="alert alert-warning mb-3">
                                        <i class="bi bi-bell me-2"></i>
                                        <strong>Sắp khởi hành trong @hoursLeft giờ nữa!</strong>
                                    </div>
                                }
                            }
                        </div>

                        <!-- Card Footer -->
                        <div class="card-footer bg-white border-top pt-3">
                            <div class="d-grid gap-2">
                                <a asp-action="TripDetails" asp-route-id="@trip.TripID"
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-info-circle me-2"></i>Xem chi tiết
                                </a>

                                @if (isActive && booking.Status == "Đã đặt")
                                {
                                    <form asp-action="CancelBooking" method="post" class="mb-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@booking.BookingID" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm w-100"
                                                onclick="return confirm('Bạn có chắc muốn hủy đặt chỗ này?')">
                                            <i class="bi bi-x-circle me-2"></i>Hủy đặt chỗ
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox text-muted" style="font-size: 5rem;"></i>
                <h4 class="mt-3 mb-2">Chưa có chuyến đi nào</h4>
                <p class="text-muted mb-4">Bạn chưa đặt chỗ cho chuyến đi nào.</p>
                <a asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-search me-2"></i>Tìm chuyến đi
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script>
        $(document).ready(function() {
            // Filter functionality
            $('#bookingFilter .nav-link').click(function(e) {
                e.preventDefault();

                $('#bookingFilter .nav-link').removeClass('active');
                $(this).addClass('active');

                var filter = $(this).data('filter');

                if (filter === 'all') {
                    $('.booking-item').fadeIn();
                } else {
                    $('.booking-item').hide();
                    $('.booking-item[data-filter="' + filter + '"]').fadeIn();
                }
            });

            // Auto dismiss alerts
            setTimeout(function() {
                $('.alert-success, .alert-danger').fadeOut('slow');
            }, 5000);

            // SignalR Connection
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/busRealtimeHub")
                .withAutomaticReconnect()
                .build();

            connection.start()
                .then(() => console.log("SignalR Connected"))
                .catch(err => console.error(err));

            // Listen for trip status changes
            connection.on("TripStatusChanged", (data) => {
                console.log("Trip status changed:", data);
                showNotification("info", `Chuyến đi #${data.tripId} đã thay đổi trạng thái: ${data.status}`);

                // Reload after a delay to show new status
                setTimeout(() => location.reload(), 3000);
            });

            function showNotification(type, message) {
                const bgColor = type === 'info' ? 'bg-info' : 'bg-primary';

                const notification = `
                    <div class="position-fixed top-0 end-0 p-3" style="z-index: 9999;">
                        <div class="toast show ${bgColor} text-white" role="alert">
                            <div class="toast-body">
                                <i class="bi bi-info-circle me-2"></i>${message}
                            </div>
                        </div>
                    </div>`;

                $('body').append(notification);
                setTimeout(() => $('.toast').remove(), 5000);
            }
        });
    </script>
}

<style>
    .booking-item {
        transition: all 0.3s ease;
    }

    .card:hover {
        transform: translateY(-3px);
        box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15) !important;
    }

    .nav-pills .nav-link {
        color: #6c757d;
        border-radius: 8px;
        margin-right: 0.5rem;
    }

        .nav-pills .nav-link:hover {
            background-color: #f8f9fa;
        }

        .nav-pills .nav-link.active {
            background-color: #0d6efd;
            color: white;
        }

    .progress-bar-animated {
        animation: progress-bar-stripes 1s linear infinite;
    }
</style>
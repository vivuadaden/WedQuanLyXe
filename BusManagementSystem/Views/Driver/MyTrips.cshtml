@model IEnumerable<BusManagementSystem.Models.Trip>

@{
    ViewData["Title"] = "Chuyến đi của tôi";
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="fw-bold">
                <i class="bi bi-list-ul me-2"></i>Chuyến đi của tôi
            </h2>
            <p class="text-muted">Quản lý tất cả các chuyến đi bạn đã đăng ký</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="RegisterTrip" class="btn btn-primary">
                <i class="bi bi-plus-circle me-2"></i>Đăng ký chuyến mới
            </a>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filter Tabs -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <ul class="nav nav-pills" id="statusFilter">
                <li class="nav-item">
                    <a class="nav-link active" href="#" data-status="all">
                        <i class="bi bi-grid-fill me-2"></i>Tất cả
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#" data-status="Chờ xác nhận">
                        <i class="bi bi-clock me-2"></i>Chờ xác nhận
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#" data-status="Đã xác nhận">
                        <i class="bi bi-check-circle me-2"></i>Đã xác nhận
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#" data-status="Đang đi">
                        <i class="bi bi-arrow-repeat me-2"></i>Đang đi
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#" data-status="Hoàn thành">
                        <i class="bi bi-check-square me-2"></i>Hoàn thành
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#" data-status="Hủy">
                        <i class="bi bi-x-circle me-2"></i>Đã hủy
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <!-- Trips List -->
    @if (Model.Any())
    {
        <div class="row g-4" id="tripsList">
            @foreach (var trip in Model)
            {
                <div class="col-md-6 col-lg-4 trip-item" data-status="@trip.Status">
                    <div class="card border-0 shadow-sm h-100">
                        <!-- Card Header with Status -->
                        <div class="card-header border-0 bg-white py-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="mb-0 fw-bold">
                                    <i class="bi bi-bus-front text-primary me-2"></i>
                                    @trip.Bus?.BusNumber
                                </h5>
                                @if (trip.Status == "Chờ xác nhận")
                                {
                                    <span class="badge bg-warning text-dark">
                                        <i class="bi bi-clock me-1"></i>Chờ xác nhận
                                    </span>
                                }
                                else if (trip.Status == "Đã xác nhận")
                                {
                                    <span class="badge bg-success">
                                        <i class="bi bi-check-circle me-1"></i>Đã xác nhận
                                    </span>
                                }
                                else if (trip.Status == "Đang đi")
                                {
                                    <span class="badge bg-primary">
                                        <i class="bi bi-arrow-repeat me-1"></i>Đang đi
                                    </span>
                                }
                                else if (trip.Status == "Hoàn thành")
                                {
                                    <span class="badge bg-info">
                                        <i class="bi bi-check-square me-1"></i>Hoàn thành
                                    </span>
                                }
                                else if (trip.Status == "Hủy")
                                {
                                    <span class="badge bg-secondary">
                                        <i class="bi bi-x-circle me-1"></i>Đã hủy
                                    </span>
                                }
                            </div>
                        </div>

                        <!-- Card Body -->
                        <div class="card-body">
                            <!-- Route -->
                            <div class="mb-3">
                                <h6 class="fw-bold text-primary mb-2">
                                    @trip.FromCampus?.CampusName
                                </h6>
                                <div class="text-center my-2">
                                    <i class="bi bi-arrow-down text-muted"></i>
                                </div>
                                <h6 class="fw-bold text-success">
                                    @trip.ToCampus?.CampusName
                                </h6>
                            </div>

                            <hr>

                            <!-- Trip Details -->
                            <div class="mb-2">
                                <small class="text-muted d-block mb-1">
                                    <i class="bi bi-calendar3 me-2"></i>Ngày khởi hành
                                </small>
                                <strong>@trip.DepartureTime.ToString("dd/MM/yyyy")</strong>
                            </div>

                            <div class="mb-2">
                                <small class="text-muted d-block mb-1">
                                    <i class="bi bi-clock me-2"></i>Giờ khởi hành
                                </small>
                                <strong>@trip.DepartureTime.ToString("HH:mm")</strong>
                            </div>

                            <div class="mb-3">
                                <small class="text-muted d-block mb-1">
                                    <i class="bi bi-people me-2"></i>Số chỗ còn trống
                                </small>
                                <div class="progress" style="height: 20px;">
                                    @{
                                        var capacity = trip.Bus?.Capacity ?? 31;
                                        var booked = capacity - trip.AvailableSeats;
                                        var percentage = (booked * 100) / capacity;
                                        var progressColor = percentage < 50 ? "bg-success" : percentage < 80 ? "bg-warning" : "bg-danger";
                                    }
                                    <div class="progress-bar @progressColor" role="progressbar"
                                         style="width: @percentage%">
                                        <strong>@trip.AvailableSeats / @capacity</strong>
                                    </div>
                                </div>
                            </div>

                            <!-- Actions -->
                            <div class="d-grid gap-2">
                                <a asp-action="TripDetails" asp-route-id="@trip.TripID"
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-info-circle me-2"></i>Xem chi tiết
                                </a>

                                @if (trip.Status == "Chờ xác nhận")
                                {
                                    <form asp-action="CancelTrip" method="post" class="mb-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@trip.TripID" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm w-100"
                                                onclick="return confirm('Bạn có chắc muốn hủy chuyến đi này?')">
                                            <i class="bi bi-x-circle me-2"></i>Hủy chuyến
                                        </button>
                                    </form>
                                }
                                else if (trip.Status == "Đã xác nhận")
                                {
                                    <form asp-action="StartTrip" method="post" class="mb-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@trip.TripID" />
                                        <button type="submit" class="btn btn-success btn-sm w-100"
                                                onclick="return confirm('Bắt đầu chuyến đi?')">
                                            <i class="bi bi-play-circle me-2"></i>Bắt đầu
                                        </button>
                                    </form>
                                }
                                else if (trip.Status == "Đang đi")
                                {
                                    <form asp-action="CompleteTrip" method="post" class="mb-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@trip.TripID" />
                                        <button type="submit" class="btn btn-primary btn-sm w-100"
                                                onclick="return confirm('Hoàn thành chuyến đi?')">
                                            <i class="bi bi-check-circle me-2"></i>Hoàn thành
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>

                        <!-- Card Footer -->
                        <div class="card-footer bg-light border-0 py-2">
                            <small class="text-muted">
                                <i class="bi bi-clock-history me-1"></i>
                                Đăng ký: @trip.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                            </small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox text-muted" style="font-size: 5rem;"></i>
                <h4 class="mt-3 mb-2">Chưa có chuyến đi nào</h4>
                <p class="text-muted mb-4">Bạn chưa đăng ký chuyến đi nào. Hãy tạo chuyến đi đầu tiên!</p>
                <a asp-action="RegisterTrip" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-2"></i>Đăng ký chuyến mới
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Filter functionality
            $('#statusFilter .nav-link').click(function(e) {
                e.preventDefault();

                // Update active state
                $('#statusFilter .nav-link').removeClass('active');
                $(this).addClass('active');

                var status = $(this).data('status');

                if (status === 'all') {
                    $('.trip-item').fadeIn();
                } else {
                    $('.trip-item').hide();
                    $('.trip-item[data-status="' + status + '"]').fadeIn();
                }
            });

            // Auto dismiss alerts
            setTimeout(function() {
                $('.alert').fadeOut('slow');
            }, 5000);
        });
    </script>
}

<style>
    .trip-item {
        transition: all 0.3s ease;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15) !important;
    }

    .nav-pills .nav-link {
        color: #6c757d;
        border-radius: 8px;
        margin-right: 0.5rem;
    }

        .nav-pills .nav-link:hover {
            background-color: #f8f9fa;
        }

        .nav-pills .nav-link.active {
            background-color: #0d6efd;
            color: white;
        }
</style>
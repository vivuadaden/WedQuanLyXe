@model BusManagementSystem.Models.Trip

@{
    ViewData["Title"] = "Chi tiết chuyến đi";
    var bookings = ViewBag.Bookings as IEnumerable<BusManagementSystem.Models.Booking>;
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="MyTrips">Chuyến đi của tôi</a></li>
            <li class="breadcrumb-item active">Chi tiết chuyến đi #@Model.TripID</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="fw-bold">
                <i class="bi bi-info-circle me-2"></i>Chi tiết chuyến đi
            </h2>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="MyTrips" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-2"></i>Quay lại
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Trip Information -->
        <div class="col-lg-8">
            <!-- Main Info Card -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold">
                            <i class="bi bi-bus-front text-primary me-2"></i>Thông tin chuyến đi
                        </h5>
                        @if (Model.Status == "Chờ xác nhận")
                        {
                            <span class="badge bg-warning text-dark fs-6">
                                <i class="bi bi-clock me-1"></i>Chờ xác nhận
                            </span>
                        }
                        else if (Model.Status == "Đã xác nhận")
                        {
                            <span class="badge bg-success fs-6">
                                <i class="bi bi-check-circle me-1"></i>Đã xác nhận
                            </span>
                        }
                        else if (Model.Status == "Đang đi")
                        {
                            <span class="badge bg-primary fs-6">
                                <i class="bi bi-arrow-repeat me-1"></i>Đang đi
                            </span>
                        }
                        else if (Model.Status == "Hoàn thành")
                        {
                            <span class="badge bg-info fs-6">
                                <i class="bi bi-check-square me-1"></i>Hoàn thành
                            </span>
                        }
                        else if (Model.Status == "Hủy")
                        {
                            <span class="badge bg-secondary fs-6">
                                <i class="bi bi-x-circle me-1"></i>Đã hủy
                            </span>
                        }
                    </div>
                </div>
                <div class="card-body p-4">
                    <!-- Route -->
                    <div class="row mb-4">
                        <div class="col-md-5">
                            <div class="text-center p-3 bg-light rounded">
                                <i class="bi bi-geo-alt-fill text-primary fs-1"></i>
                                <h5 class="mt-2 mb-0 fw-bold">@Model.FromCampus?.CampusName</h5>
                                <small class="text-muted">Điểm khởi hành</small>
                            </div>
                        </div>
                        <div class="col-md-2 d-flex align-items-center justify-content-center">
                            <i class="bi bi-arrow-right text-primary" style="font-size: 2rem;"></i>
                        </div>
                        <div class="col-md-5">
                            <div class="text-center p-3 bg-light rounded">
                                <i class="bi bi-geo-alt-fill text-success fs-1"></i>
                                <h5 class="mt-2 mb-0 fw-bold">@Model.ToCampus?.CampusName</h5>
                                <small class="text-muted">Điểm đến</small>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <!-- Details Grid -->
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-bus-front text-primary fs-4 me-3"></i>
                                <div>
                                    <small class="text-muted d-block">Xe buýt</small>
                                    <h6 class="mb-0">@Model.Bus?.BusNumber</h6>
                                    <small class="text-muted">@Model.Bus?.LicensePlate</small>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-person-badge text-primary fs-4 me-3"></i>
                                <div>
                                    <small class="text-muted d-block">Tài xế</small>
                                    <h6 class="mb-0">@Model.Driver?.FullName</h6>
                                    <small class="text-muted">@Model.Driver?.PhoneNumber</small>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-calendar3 text-primary fs-4 me-3"></i>
                                <div>
                                    <small class="text-muted d-block">Ngày khởi hành</small>
                                    <h6 class="mb-0">@Model.DepartureTime.ToString("dd/MM/yyyy")</h6>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-clock text-primary fs-4 me-3"></i>
                                <div>
                                    <small class="text-muted d-block">Giờ khởi hành</small>
                                    <h6 class="mb-0">@Model.DepartureTime.ToString("HH:mm")</h6>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-flag-fill text-success fs-4 me-3"></i>
                                <div>
                                    <small class="text-muted d-block">Dự kiến đến</small>
                                    <h6 class="mb-0">
                                        @(Model.EstimatedArrivalTime?.ToString("HH:mm") ?? "Chưa xác định")
                                    </h6>
                                </div>
                            </div>
                        </div>

                        @if (Model.ActualArrivalTime.HasValue)
                        {
                            <div class="col-md-6">
                                <div class="d-flex align-items-start">
                                    <i class="bi bi-check-circle-fill text-info fs-4 me-3"></i>
                                    <div>
                                        <small class="text-muted d-block">Thời gian đến thực tế</small>
                                        <h6 class="mb-0">@Model.ActualArrivalTime.Value.ToString("HH:mm")</h6>
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="col-md-6">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-people-fill text-primary fs-4 me-3"></i>
                                <div>
                                    <small class="text-muted d-block">Số chỗ</small>
                                    <h6 class="mb-0">
                                        Còn trống: @Model.AvailableSeats / @Model.Bus?.Capacity
                                    </h6>
                                    <div class="progress mt-2" style="height: 8px;">
                                        @{
                                            var capacity = Model.Bus?.Capacity ?? 31;
                                            var booked = capacity - Model.AvailableSeats;
                                            var percentage = (booked * 100) / capacity;
                                            var progressColor = percentage < 50 ? "bg-success" : percentage < 80 ? "bg-warning" : "bg-danger";
                                        }
                                        <div class="progress-bar @progressColor"
                                             style="width: @percentage%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-clock-history text-muted fs-4 me-3"></i>
                                <div>
                                    <small class="text-muted d-block">Ngày tạo</small>
                                    <h6 class="mb-0">@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</h6>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bookings List -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-people text-primary me-2"></i>
                        Danh sách sinh viên đã đặt chỗ
                        <span class="badge bg-primary ms-2">@(bookings?.Count() ?? 0)</span>
                    </h5>
                </div>
                <div class="card-body p-0">
                    @if (bookings != null && bookings.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">STT</th>
                                        <th>Họ tên</th>
                                        <th>Email</th>
                                        <th>Số điện thoại</th>
                                        <th>Thời gian đặt</th>
                                        <th class="text-center">Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var index = 1;
                                        foreach (var booking in bookings)
                                        {
                                            <tr>
                                                <td class="ps-4">@index</td>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2"
                                                             style="width: 35px; height: 35px;">
                                                            <i class="bi bi-person"></i>
                                                        </div>
                                                        <strong>@booking.Student?.FullName</strong>
                                                    </div>
                                                </td>
                                                <td>@booking.Student?.Email</td>
                                                <td>@booking.Student?.PhoneNumber</td>
                                                <td>@booking.BookingTime.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td class="text-center">
                                                    <span class="badge bg-success">
                                                        <i class="bi bi-check-circle me-1"></i>@booking.Status
                                                    </span>
                                                </td>
                                            </tr>
                                            index++;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                            <p class="text-muted mt-3 mb-0">Chưa có sinh viên nào đặt chỗ</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Actions Sidebar -->
        <div class="col-lg-4">
            <!-- Actions Card -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-primary text-white py-3">
                    <h6 class="mb-0 fw-bold">
                        <i class="bi bi-lightning-charge me-2"></i>Thao tác
                    </h6>
                </div>
                <div class="card-body p-3">
                    <div class="d-grid gap-2">
                        @if (Model.Status == "Chờ xác nhận")
                        {
                            <div class="alert alert-warning mb-2">
                                <i class="bi bi-info-circle me-2"></i>
                                <small>Chuyến đi đang chờ admin xác nhận</small>
                            </div>
                            <form asp-action="CancelTrip" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.TripID" />
                                <button type="submit" class="btn btn-danger w-100"
                                        onclick="return confirm('Bạn có chắc muốn hủy chuyến đi này?')">
                                    <i class="bi bi-x-circle me-2"></i>Hủy chuyến đi
                                </button>
                            </form>
                        }
                        else if (Model.Status == "Đã xác nhận")
                        {
                            <form asp-action="StartTrip" method="post" class="mb-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.TripID" />
                                <button type="submit" class="btn btn-success w-100"
                                        onclick="return confirm('Bắt đầu chuyến đi?')">
                                    <i class="bi bi-play-circle me-2"></i>Bắt đầu chuyến đi
                                </button>
                            </form>
                        }
                        else if (Model.Status == "Đang đi")
                        {
                            <div class="alert alert-primary mb-2">
                                <i class="bi bi-arrow-repeat me-2"></i>
                                <small>Chuyến đi đang diễn ra</small>
                            </div>
                            <form asp-action="CompleteTrip" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.TripID" />
                                <button type="submit" class="btn btn-primary w-100"
                                        onclick="return confirm('Hoàn thành chuyến đi?')">
                                    <i class="bi bi-check-circle me-2"></i>Hoàn thành chuyến
                                </button>
                            </form>
                        }
                        else if (Model.Status == "Hoàn thành")
                        {
                            <div class="alert alert-success mb-0">
                                <i class="bi bi-check-circle me-2"></i>
                                <small>Chuyến đi đã hoàn thành</small>
                            </div>
                        }
                        else if (Model.Status == "Hủy")
                        {
                            <div class="alert alert-secondary mb-0">
                                <i class="bi bi-x-circle me-2"></i>
                                <small>Chuyến đi đã bị hủy</small>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Statistics -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-bold">
                        <i class="bi bi-graph-up me-2"></i>Thống kê
                    </h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <small class="text-muted">Tổng số chỗ</small>
                            <strong>@Model.Bus?.Capacity</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-1">
                            <small class="text-muted">Đã đặt</small>
                            <strong class="text-primary">@((Model.Bus?.Capacity ?? 31) - Model.AvailableSeats)</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-1">
                            <small class="text-muted">Còn trống</small>
                            <strong class="text-success">@Model.AvailableSeats</strong>
                        </div>
                        <div class="d-flex justify-content-between">
                            <small class="text-muted">Tỷ lệ lấp đầy</small>
                            <strong class="text-info">
                                @{
                                    var fillRate = ((Model.Bus?.Capacity ?? 31) - Model.AvailableSeats) * 100 / (Model.Bus?.Capacity ?? 31);
                                }
                                @fillRate.ToString("F1")%
                            </strong>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Timeline -->
            @if (Model.ApprovedDate.HasValue || Model.ActualArrivalTime.HasValue)
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom py-3">
                        <h6 class="mb-0 fw-bold">
                            <i class="bi bi-clock-history me-2"></i>Lịch sử
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="timeline">
                            <div class="timeline-item mb-3">
                                <i class="bi bi-plus-circle text-primary"></i>
                                <div class="ms-3">
                                    <small class="text-muted d-block">Đăng ký</small>
                                    <strong>@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</strong>
                                </div>
                            </div>
                            @if (Model.ApprovedDate.HasValue)
                            {
                                <div class="timeline-item mb-3">
                                    <i class="bi bi-check-circle text-success"></i>
                                    <div class="ms-3">
                                        <small class="text-muted d-block">Được xác nhận</small>
                                        <strong>@Model.ApprovedDate.Value.ToString("dd/MM/yyyy HH:mm")</strong>
                                    </div>
                                </div>
                            }
                            @if (Model.ActualArrivalTime.HasValue)
                            {
                                <div class="timeline-item">
                                    <i class="bi bi-flag-fill text-info"></i>
                                    <div class="ms-3">
                                        <small class="text-muted d-block">Hoàn thành</small>
                                        <strong>@Model.ActualArrivalTime.Value.ToString("dd/MM/yyyy HH:mm")</strong>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script>
        // SignalR for realtime seat updates
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/busRealtimeHub")
            .withAutomaticReconnect()
            .build();

        connection.start()
            .then(() => {
                console.log("SignalR Connected");
                // Join this trip's group for updates
                connection.invoke("JoinTripGroup", @Model.TripID);
            })
            .catch(err => console.error(err));

        // Listen for seat availability changes
        connection.on("SeatAvailabilityChanged", (data) => {
            if (data.tripId === @Model.TripID) {
                location.reload();
            }
        });
    </script>
}

<style>
    .timeline-item {
        display: flex;
        align-items: start;
    }

        .timeline-item i {
            font-size: 1.25rem;
        }

    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
        cursor: pointer;
    }
</style>
@model IEnumerable<BusManagementSystem.Models.Bus>

@{
    ViewData["Title"] = "Quản lý xe";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h2><i class="bi bi-bus-front-fill"></i> Quản lý xe buýt</h2>
        </div>
        <div class="col-md-6 text-end">
            <a asp-action="CreateBus" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Thêm xe mới
            </a>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="card shadow">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead class="table-dark">
                            <tr>
                                <th>Số xe</th>
                                <th>Biển số</th>
                                <th>Sức chứa</th>
                                <th>Trạng thái</th>
                                <th>Ngày tạo</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var bus in Model)
                            {
                                <tr class="@(!bus.IsActive ? "table-secondary" : "")">
                                    <td><strong>@bus.BusNumber</strong></td>
                                    <td>
                                        <span class="badge bg-dark">@bus.LicensePlate</span>
                                    </td>
                                    <td>@bus.Capacity chỗ</td>
                                    <td>
                                        @if (bus.Status == "Sẵn sàng")
                                        {
                                            <span class="badge bg-success">@bus.Status</span>
                                        }
                                        else if (bus.Status == "Đang hoạt động")
                                        {
                                            <span class="badge bg-warning text-dark">@bus.Status</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@bus.Status</span>
                                        }
                                    </td>
                                    <td>@bus.CreatedDate.ToString("dd/MM/yyyy")</td>
                                    <td class="text-center">
                                        <a asp-action="EditBus" asp-route-id="@bus.BusID"
                                           class="btn btn-sm btn-outline-primary"
                                           title="Chỉnh sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @if (bus.Status == "Sẵn sàng")
                                        {
                                            <button class="btn btn-sm btn-outline-danger delete-bus-btn"
                                                    data-bus-id="@bus.BusID"
                                                    data-bus-number="@bus.BusNumber"
                                                    title="Vô hiệu hóa">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Chưa có xe nào trong hệ thống. Hãy thêm xe mới!
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).on('click', '.delete-bus-btn', function() {
            const busId = $(this).data('bus-id');
            const busNumber = $(this).data('bus-number');

            if (confirm(`Bạn có chắc muốn vô hiệu hóa xe ${busNumber}?`)) {
                $.ajax({
                    url: '@Url.Action("DeleteBus", "Admin")',
                    type: 'POST',
                    data: {
                        id: busId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert(response.message);
                        }
                    },
                    error: function() {
                        alert('Có lỗi xảy ra!');
                    }
                });
            }
        });
    </script>
}

@Html.AntiForgeryToken()
@model BusManagementSystem.Models.Trip

@{
    ViewData["Title"] = "Chi tiết chuyến đi";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <a asp-action="Trips" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="row">
        <!-- Thông tin chuyến đi -->
        <div class="col-md-6 mb-4">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5><i class="bi bi-info-circle"></i> Thông tin chuyến đi</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <strong>Mã chuyến:</strong> #@Model.TripID
                    </div>
                    <div class="mb-3">
                        <strong>Xe:</strong> @Model.Bus?.BusNumber (@Model.Bus?.LicensePlate)
                    </div>
                    <div class="mb-3">
                        <strong>Tài xế:</strong> @Model.Driver?.FullName<br>
                        <small class="text-muted">
                            <i class="bi bi-telephone"></i> @Model.Driver?.PhoneNumber
                        </small>
                    </div>
                    <div class="mb-3">
                        <strong>Tuyến đường:</strong><br>
                        <span class="text-primary">@Model.FromCampus?.CampusName</span>
                        <i class="bi bi-arrow-right"></i>
                        <span class="text-success">@Model.ToCampus?.CampusName</span>
                    </div>
                    <div class="mb-3">
                        <strong>Khởi hành:</strong> @Model.DepartureTime.ToString("HH:mm - dd/MM/yyyy")
                    </div>
                    @if (Model.EstimatedArrivalTime.HasValue)
                    {
                        <div class="mb-3">
                            <strong>Dự kiến đến:</strong> @Model.EstimatedArrivalTime.Value.ToString("HH:mm - dd/MM/yyyy")
                        </div>
                    }
                    @if (Model.ActualArrivalTime.HasValue)
                    {
                        <div class="mb-3">
                            <strong>Đến thực tế:</strong> @Model.ActualArrivalTime.Value.ToString("HH:mm - dd/MM/yyyy")
                        </div>
                    }
                    <div class="mb-3">
                        <strong>Trạng thái:</strong>
                        @if (Model.Status == "Chờ xác nhận")
                        {
                            <span class="badge bg-warning text-dark">@Model.Status</span>
                        }
                        else if (Model.Status == "Đã xác nhận")
                        {
                            <span class="badge bg-success">@Model.Status</span>
                        }
                        else if (Model.Status == "Đang đi")
                        {
                            <span class="badge bg-info">@Model.Status</span>
                        }
                        else if (Model.Status == "Hoàn thành")
                        {
                            <span class="badge bg-secondary">@Model.Status</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">@Model.Status</span>
                        }
                    </div>
                    <div class="mb-3">
                        <strong>Số chỗ:</strong>
                        <div class="progress" style="height: 30px;">
                            @{
                                var occupied = 31 - Model.AvailableSeats;
                                var percentage = (occupied * 100.0) / 31;
                            }
                            <div class="progress-bar @(percentage >= 80 ? "bg-danger" : percentage >= 50 ? "bg-warning" : "bg-success")"
                                 style="width: @percentage%">
                                @occupied/31 đã đặt
                            </div>
                        </div>
                        <small class="text-muted">Còn trống: @Model.AvailableSeats chỗ</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Danh sách sinh viên đã đặt -->
        <div class="col-md-6 mb-4">
            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <h5><i class="bi bi-people"></i> Danh sách sinh viên (@(Model.Bookings?.Count(b => b.Status == "Đã đặt") ?? 0))</h5>
                </div>
                <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                    @if (Model.Bookings != null && Model.Bookings.Any(b => b.Status == "Đã đặt"))
                    {
                        <div class="list-group">
                            @foreach (var booking in Model.Bookings.Where(b => b.Status == "Đã đặt").OrderBy(b => b.BookingTime))
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">@booking.Student?.FullName</h6>
                                            <small class="text-muted">
                                                <i class="bi bi-envelope"></i> @booking.Student?.Email<br>
                                                <i class="bi bi-telephone"></i> @booking.Student?.PhoneNumber
                                            </small>
                                        </div>
                                        <small class="text-muted">
                                            @booking.BookingTime.ToString("HH:mm dd/MM")
                                        </small>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center">Chưa có sinh viên nào đặt chỗ</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Lịch sử trạng thái -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header bg-secondary text-white">
                    <h5><i class="bi bi-clock-history"></i> Lịch sử trạng thái</h5>
                </div>
                <div class="card-body">
                    @if (Model.StatusHistories != null && Model.StatusHistories.Any())
                    {
                        <div class="timeline">
                            @foreach (var history in Model.StatusHistories.OrderByDescending(h => h.ChangedDate))
                            {
                                <div class="timeline-item mb-3">
                                    <div class="row">
                                        <div class="col-md-2 text-end">
                                            <small class="text-muted">
                                                @history.ChangedDate.ToString("HH:mm")<br>
                                                @history.ChangedDate.ToString("dd/MM/yyyy")
                                            </small>
                                        </div>
                                        <div class="col-md-10">
                                            <div class="alert alert-light mb-2">
                                                <strong>@history.ChangedByUser?.FullName</strong>
                                                @if (!string.IsNullOrEmpty(history.OldStatus))
                                                {
                                                    <span> đã thay đổi từ <span class="badge bg-secondary">@history.OldStatus</span></span>
                                                }
                                                <span> sang <span class="badge bg-primary">@history.NewStatus</span></span>
                                                @if (!string.IsNullOrEmpty(history.Notes))
                                                {
                                                    <br>

                                                    <small class="text-muted">Ghi chú: @history.Notes</small>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Chưa có lịch sử</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .timeline-item {
            border-left: 2px solid #dee2e6;
            padding-left: 20px;
            position: relative;
        }

            .timeline-item::before {
                content: '';
                width: 12px;
                height: 12px;
                background: #0d6efd;
                border-radius: 50%;
                position: absolute;
                left: -7px;
                top: 5px;
            }
    </style>
}